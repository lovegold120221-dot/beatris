rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Primitive Definition
    // -------------------------------------------------------------------------
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerifiedEmail() { return request.auth.token.email_verified == true; }

    // -------------------------------------------------------------------------
    // Entities Validation
    // -------------------------------------------------------------------------
    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt']) 
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }
    
    function isValidUserUpdate(data) {
      return data.updatedAt == request.time
          && data.email == existing().email 
          && data.createdAt == existing().createdAt;
    }

    function isValidMemoryCreate(data, userId) {
      return data.keys().hasAll(['userId', 'content', 'type', 'createdAt', 'updatedAt'])
        && data.userId == userId
        && data.content is string && data.content.size() <= 5000
        && data.type is string 
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }
    
    function isValidMemoryUpdate(data, userId) {
      return data.content is string && data.content.size() <= 5000
        && data.updatedAt == request.time
        && data.userId == existing().userId
        && data.createdAt == existing().createdAt;
    }

    function isValidFileCreate(data, userId) {
      return data.keys().hasAll(['userId', 'filename', 'mimeType', 'size', 'storageUrl', 'createdAt', 'status', 'type'])
        && data.userId == userId
        && data.filename is string 
        && data.createdAt == request.time;
    }

    function isValidAnnotationCreate(data, userId) {
      return data.keys().hasAll(['userId', 'fileId', 'textSelection', 'comment', 'createdAt'])
        && data.userId == userId
        && data.fileId is string 
        && data.createdAt == request.time;
    }

    function isValidReminderCreate(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'dueDate', 'completed', 'createdAt'])
        && data.userId == userId
        && data.title is string 
        && data.createdAt == request.time;
    }

    function isValidReminderUpdate(data, userId) {
      return data.userId == existing().userId
        && data.createdAt == existing().createdAt;
    }

    // -------------------------------------------------------------------------
    // Routes and Access Rules
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No list on users
      
      allow create: if isValidId(userId) 
                    && isOwner(userId) 
                    && isValidUserCreate(incoming());
                    
      allow update: if isValidId(userId)
                    && isOwner(userId)
                    && isValidUserUpdate(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt']);

      allow delete: if false;

      // Subcollections
      match /memories/{memoryId} {
        allow get: if isOwner(userId) && isValidId(memoryId);
        allow list: if isOwner(userId);

        allow create: if isValidId(memoryId)
                      && isOwner(userId)
                      && isValidMemoryCreate(incoming(), userId);
                      
        allow update: if isValidId(memoryId)
                      && isOwner(userId)
                      && isValidMemoryUpdate(incoming(), userId)
                      && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'type', 'sourceUrl', 'updatedAt']);
                      
        allow delete: if isValidId(memoryId) && isOwner(userId);
      }

      match /files/{fileId} {
        allow get: if isOwner(userId) && isValidId(fileId);
        allow list: if isOwner(userId);

        allow create: if isValidId(fileId)
                      && isOwner(userId)
                      && isValidFileCreate(incoming(), userId);
                      
        allow update: if false; // file metadata should be immutable 
        
        allow delete: if isValidId(fileId) && isOwner(userId);
      }

      match /annotations/{annotationId} {
        allow list: if isOwner(userId);
        allow create: if isValidId(annotationId) && isOwner(userId) && isValidAnnotationCreate(incoming(), userId);
        allow delete: if isValidId(annotationId) && isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(reminderId);
        allow create: if isValidId(reminderId) && isOwner(userId) && isValidReminderCreate(incoming(), userId);
        allow update: if isValidId(reminderId) && isOwner(userId) && isValidReminderUpdate(incoming(), userId);
        allow delete: if isValidId(reminderId) && isOwner(userId);
      }
    }
  }
}
